import time
import random
#функция линейной проверки
def search(arr,i):
    for x in arr:
        if x==i:
            return True
    return False
#нахождение второго максимума
def searchsecmax(arr):
    if len(arr) < 2:
        return None
    unique_arr = list(set(arr))
    if len(unique_arr) < 2:
        return None
    unique_arr.sort()
    return unique_arr[-2]
#бинарный поиск
def searchbin(arr,x):
    arr.sort()
    lt=0
    rt=len(arr)-1
    while lt<=rt:
        mid=(lt+rt)//2
        if arr[mid]==x:
            return True
        if arr[mid]<x:
            lt=mid+1
        if arr[mid]>x:
            rt=mid-1
    return False
#таблица умножения
def multiptable(n):
    table = []
    for i in range(1, n + 1):
        row = []
        for j in range(1, n + 1):
            row.append(i * j)
        table.append(row)
    return table
#измерение времени
def measuretime(func, *args):
    start = time.perf_counter()
    result = func(*args)
    end = time.perf_counter()
    return end - start
#генерация случайного массива
def generarray(n):
    return [random.randint(0, 10000) for _ in range(n)]
if __name__=='__main__':
    sz=[100,1000,5000,10000]
    for n in sz:
        print(n)
        a=generarray(n)
        el=random.choice(a)
        t=measuretime(search,a,el)
        print('линейная проверка',t)
        t = measuretime(searchsecmax, a)
        print("второй максимум:",t)

        a = sorted(a)
        t = measuretime(searchbin, a, el)
        print("бинарный поиск:",t)

        t = measuretime(multiptable, n)
        print("таблица умножения:",n,t)

        print("")
